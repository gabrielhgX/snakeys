generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                               String               @id @default(uuid())
  email                            String               @unique
  cpf                              String               @unique @db.VarChar(11)
  password                         String
  emailVerified                    Boolean              @default(false)
  emailVerificationToken           String?              @unique
  emailVerificationTokenExpiresAt  DateTime?
  createdAt                        DateTime             @default(now())

  // ── Progression ───────────────────────────────────────────────────────
  accountXp     Int    @default(0)
  seasonXp      Int    @default(0)

  // FK to the currently-equipped UserItem of type SKIN. Not enforced as
  // a strict relation field because Prisma struggles with the
  // bidirectional UserItem.equippedBy back-relation when `userItems` is
  // already present. We validate in service code instead.
  equippedSkinId String? @unique

  wallet                           Wallet?
  transactions                     Transaction[]
  userItems                        UserItem[]
  listings                         MarketplaceListing[]
  battlePassClaims                 UserBattlePassClaim[]
  matches                          Match[]
}

model Wallet {
  id               String   @id @default(uuid())
  userId           String   @unique
  balanceAvailable Decimal  @default(0) @db.Decimal(18, 8)
  balanceLocked    Decimal  @default(0) @db.Decimal(18, 8)
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id])
}

model Transaction {
  id             String            @id @default(uuid())
  userId         String
  type           TransactionType
  amount         Decimal           @db.Decimal(18, 8)
  status         TransactionStatus @default(COMPLETED)
  createdAt      DateTime          @default(now())
  // For BET transactions: stores the game mode ('hunt-hunt' | 'big-fish' | 'private').
  // Used by settleMatchForUser() to enforce ghost-period validation without an extra table.
  referenceId    String?
  matchId        String?
  idempotencyKey String?           @unique
  user           User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([matchId])
}

// Primary idempotency guard for match settlement.
// A unique row per (userId, matchId) is created at the START of processMatchResult(),
// inside the same PostgreSQL transaction as the wallet update.  Because PostgreSQL
// acquires a write-intent lock on the unique index entry immediately on INSERT, a
// second concurrent transaction trying to create the same row will BLOCK until the
// first commits, then fail with P2002 — ensuring the wallet is debited exactly once.
model MatchSettlement {
  id        String   @id @default(uuid())
  userId    String
  matchId   String
  payout    Decimal  @db.Decimal(18, 8)
  createdAt DateTime @default(now())

  @@unique([userId, matchId])
  @@index([userId])
}

// Audit record for every kill event in a match.
// Written asynchronously by KillProcessorWorker.  Does NOT move wallet
// balances directly — that happens in processMatchResult() at match end.
//
// Idempotency: `kill:<matchId>:<victimId>` is unique because a player can
// only die once per match.  A game-server retry produces P2002 → no-op.
//
// `victimGrossPot`  = victim's accumulated pot at the moment of death
// `rake`            = house cut (10% of grossPot)
// `netTransferred`  = pot transferred to killer (grossPot - rake)
model KillEvent {
  id              String   @id @default(uuid())
  matchId         String
  killerId        String
  victimId        String
  victimGrossPot  Decimal  @db.Decimal(18, 8)
  rake            Decimal  @db.Decimal(18, 8)
  netTransferred  Decimal  @db.Decimal(18, 8)
  idempotencyKey  String   @unique  // kill:<matchId>:<victimId>
  createdAt       DateTime @default(now())

  @@index([matchId])
  @@index([killerId])
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  BET
  WIN
  FEE
  ITEM_PURCHASE
  ITEM_SALE
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

// ─── Match Lifecycle ──────────────────────────────────────────────────────────

// SPRINT 6 — Compliance audit §2.1 suggests a 5-state machine
// (BETTING | ACTIVE | SETTLING | SETTLED | ABANDONED).  We intentionally
// collapse it to 3 states because our flow is atomic:
//   • processBetEntry() creates the Match row as ACTIVE inside the SAME
//     Prisma transaction that locks the Wallet balance, so there is no
//     observable "BETTING" window between debit and match start.
//   • processMatchResult() flips ACTIVE → SETTLED in the SAME transaction
//     that credits the payout, so there is no observable "SETTLING"
//     window either.
//   • Reconciliation only needs to act on rows stuck in ACTIVE; BETTING
//     and SETTLING would be unreachable states in our pipeline.
// The simplification is documented here so future refactors that split
// the bet/start or settle/credit phases MUST reintroduce the missing
// states AND update reconcileAbandonedMatches() accordingly.
enum MatchStatus {
  ACTIVE    // BET locked + match in progress (merges audit's BETTING+ACTIVE+SETTLING)
  SETTLED   // processMatchResult() completed successfully
  ABANDONED // reconciler timed out — bet refunded to balanceAvailable
}

// Tracks one user's participation in a match.  One row per (userId, matchId).
// In online mode multiple users share the same matchId (the game-room ID),
// each with their own row and their own betAmount.
//
// Lifecycle:
//   ACTIVE    → created atomically with the BET transaction in processBetEntry()
//   SETTLED   → updated atomically inside processMatchResult() on success
//   ABANDONED → updated by MatchReconciliationService when a match stays ACTIVE
//               longer than ABANDON_AFTER_MS without a MatchSettlement record
//
// The @@index([status, createdAt]) is the reconciler's primary read path:
//   WHERE status = 'ACTIVE' AND createdAt < <cutoff>
model Match {
  id        String      @id @default(uuid())
  matchId   String      // game-room / session identifier
  userId    String
  mode      String      // 'hunt-hunt' | 'big-fish' | 'private'
  status    MatchStatus @default(ACTIVE)
  betAmount Decimal     @db.Decimal(18, 8)
  // SPRINT 3: set by processMatchResult() when the game-server reports its
  // authoritative final mass.  Null for offline (client-driven) matches.
  // Used by settleMatchForUser() to detect client-reported mass discrepancies.
  finalMass Decimal?    @db.Decimal(18, 8)
  // SPRINT 6: client IP at BET time.  Used by CollusionService to detect
  // two different userIds joining the same matchId from the same network
  // (pot-farming between alt accounts).  Nullable so old rows and offline
  // / private-room matches without a socket still validate.
  ipAddress String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id])

  @@unique([userId, matchId])
  @@index([status, createdAt])
  @@index([matchId, ipAddress])
}

model RevokedToken {
  jti       String   @id
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// ─── Cosméticos e Marketplace ─────────────────────────────────────────────────

enum ItemType {
  SKIN
  HAT
  EMOTE
  PROFILE_BACKGROUND
  PROFILE_FRAME
}

enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED
}

// Catalog of games in the platform. Skins / cosmetics are tied to a
// `gameId` so the same account + Battle Pass progress can host multiple
// games over time. Cross-platform cosmetics (e.g. profile frames that
// apply everywhere) leave `Item.gameId` null.
model Game {
  id          String   @id  // slug: "snakeys", "pong-royale", etc.
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  items       Item[]
}

model Item {
  id          String     @id @default(uuid())
  name        String
  description String?
  type        ItemType
  rarity      Rarity
  imageUrl    String?
  // null = platform-wide (e.g. PROFILE_FRAME, profile cosmetic). Otherwise
  // the cosmetic is scoped to one game's renderer.
  gameId      String?
  createdAt   DateTime   @default(now())
  game        Game?      @relation(fields: [gameId], references: [id])
  userItems   UserItem[]

  @@index([gameId])
  @@index([type, rarity])
}

// Owned instance of an `Item`. Each row is a unique mint with:
//  - `serialNumber`: globally autoincrementing — used for collector
//    pride ("snake skin #42 of all time") and also as a stable sort key
//    in the marketplace UI.
//  - `floatValue`: random in [0, 1] at mint time. Lower is better (CS:GO
//    convention). Renderer modulates opacity / weathering by this.
//  - `obtainedAt` doubles as the spec's `mintedAt`.
model UserItem {
  id            String              @id @default(uuid())
  userId        String
  itemId        String
  serialNumber  Int                 @unique @default(autoincrement())
  floatValue    Float               @default(0)
  obtainedAt    DateTime            @default(now())
  // Incremented by WalletService each time a match is settled while this
  // skin is equipped. Read-only from the client — drives the "lore" stat
  // ("X partidas jogadas com esta skin") shown in the inventory detail panel.
  usageCount    Int                 @default(0)
  user          User                @relation(fields: [userId], references: [id])
  item          Item                @relation(fields: [itemId], references: [id])
  listing       MarketplaceListing?

  @@index([userId])
  @@index([serialNumber])
}

model MarketplaceListing {
  id         String        @id @default(uuid())
  userItemId String        @unique
  sellerId   String
  price      Decimal       @db.Decimal(18, 8)
  status     ListingStatus @default(ACTIVE)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  userItem   UserItem      @relation(fields: [userItemId], references: [id])
  seller     User          @relation(fields: [sellerId], references: [id])

  @@index([sellerId])
  @@index([status])
}

// ─── Battle Pass ──────────────────────────────────────────────────────────────

enum RewardType {
  BALANCE     // adds R$ to wallet.balanceAvailable
  XP_BONUS    // adds flat XP to both account + season counters
  SKIN        // mints a UserItem with random float from a pool
}

// Single source of truth for what each Battle Pass level grants. The
// row is identified by `level` (1..100) so a season rollover only has
// to flip a config flag elsewhere — the rewards table itself doesn't
// change unless ops wants different rewards for a new season.
//
// Discriminated columns:
//   - rewardType=BALANCE  → uses `balanceAmount`
//   - rewardType=XP_BONUS → uses `xpAmount`
//   - rewardType=SKIN     → uses `skinGameId` + `skinRarity` to pick a
//                            random Item to mint. Both are nullable for
//                            the other reward types.
//
// Seed script is responsible for filling all 100 rows.
model BattlePassReward {
  id            String     @id @default(uuid())
  level         Int        @unique
  rewardType    RewardType
  // Populated for BALANCE rewards (R$, decimal). Null otherwise.
  balanceAmount Decimal?   @db.Decimal(18, 8)
  // Populated for XP_BONUS rewards (flat int). Null otherwise.
  xpAmount      Int?
  // Populated for SKIN rewards: filters the Item pool before random pick.
  // `skinGameId` null → cross-game (rare; e.g. universal profile skin).
  skinGameId    String?
  skinRarity    Rarity?
  description   String?
  createdAt     DateTime   @default(now())
  claims        UserBattlePassClaim[]
}

// Records that user X claimed reward Y. The `(userId, level)` unique
// pair is the idempotency key — calling `claim` twice on the same level
// is a no-op once a row exists.
model UserBattlePassClaim {
  id          String           @id @default(uuid())
  userId      String
  level       Int
  claimedAt   DateTime         @default(now())
  // Snapshot of what was actually granted (e.g. for SKIN, the
  // UserItem.id minted at claim time). Useful for audits / re-rendering
  // a claim history without re-deriving from the reward table.
  grantedRef  String?
  user        User             @relation(fields: [userId], references: [id])
  reward      BattlePassReward @relation(fields: [level], references: [level])

  @@unique([userId, level])
  @@index([userId])
}
